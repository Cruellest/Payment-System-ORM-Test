# ---------------- Variáveis de Ambiente ----------------
# >>> Configurações da Aplicação <<<
FLASK_ADMIN_SWATCH=yeti
SECRET_KEY='ChavesChavesChaves voce me deixa louco'
SQLALCHEMY_TRACK_MODIFICATIONS=False
FLASK_APP=app:app
APP_PORT=5001
APP_DEBUG=True

# >>> Configurações do Banco de Dados <<<
DB_TYPE=mysql
# >>> MySQL <<<
MYSQL_ALLOW_EMPTY_PASSWORD=yes
MYSQL_ROOT_PASSWORD=raiz
DB_PASSWORD=raiz
DB_HOST=db_mysql # Nome/IP do serviço (do compose) ou da sua rede
DB_USER=mysql
DB_DATABASE=mydb
DB_PORT=3306
PMA_ARBITRARY=1

# >>> PostgreSQL + PgAdmin <<<
TZ=America/Campo_Grande
